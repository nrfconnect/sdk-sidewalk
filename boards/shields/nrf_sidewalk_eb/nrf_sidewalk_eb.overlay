			< ( 14) 0x02 0x00>,
			< ( 14) 0x03 0x00>,
			< ( 14) 0x04 0x00>,
			< ( 14) 0x07 0x00>;

		tx-power-cfg-lf-hp =
			< (  9) 0x00 0x00>,
			< ( 10) 0x00 0x00>,
			< ( 11) 0x00 0x00>,
			< ( 12) 0x00 0x00>,
			< ( 13) 0x00 0x00>,
			< ( 13) 0x01 0x00>,
			< ( 13) 0x02 0x00>,
			< ( 17) 0x02 0x00>,
			< ( 14) 0x04 0x00>,
			< ( 12) 0x00 0x01>,
			< ( 13) 0x00 0x01>,
			< ( 13) 0x01 0x01>,
			< ( 13) 0x02 0x01>,
			< ( 15) 0x00 0x02>,
			< ( 15) 0x04 0x01>,
			< ( 14) 0x02 0x02>,
