			< ( 22) 0x00 0x01>,
			< ( 22) 0x01 0x01>,
			< ( 22) 0x02 0x01>,
			< ( 22) 0x03 0x01>,
			< ( 22) 0x00 0x03>,
			< ( 22) 0x01 0x03>,
			< ( 22) 0x04 0x02>,
			< ( 22) 0x01 0x04>,
			< ( 22) 0x02 0x04>,
			< ( 22) 0x01 0x06>,
			< ( 22) 0x03 0x05>,
			< ( 22) 0x03 0x07>,
			< ( 22) 0x04 0x06>,
			< ( 22) 0x04 0x07>;

		tx-power-cfg-hf =
			< (-18) 0x04 0x00>,
			< (-18) 0x04 0x00>,
			< (-17) 0x04 0x00>,
			< (-16) 0x04 0x00>,
